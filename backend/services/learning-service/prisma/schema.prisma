datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  learner
  instructor
  admin
  domain_expert
}

enum MasteryState {
  not_started
  in_progress
  mastered
  review_needed
  relearn
}

enum QuizOutcome {
  strong_pass
  marginal_pass
  fail_low
  fail_fundamental
  fail_severe
}

enum QuestionType {
  multiple_choice
  short_answer
  code_completion
  true_false
  matching
}

enum ResourceModality {
  documentation
  tutorial
  video
  interactive
  reference
}

enum OntologyStatus {
  draft
  in_review
  verified
  published
  archived
}

enum AdaptationType {
  resource_swap
  prerequisite_review
  instructor_escalation
  decay_micro_quiz
}

enum BranchPath {
  frontend
  backend
  data_science
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String   @unique @db.VarChar(255)
  passwordHash      String?  @db.VarChar(255)
  fullName          String   @db.VarChar(255)
  role              UserRole @default(learner)
  avatarUrl         String?
  oauthProvider     String?  @db.VarChar(50)
  oauthProviderId   String?  @db.VarChar(255)
  preferredLanguage String   @default("en") @db.VarChar(10)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  createdOntologyVersions  OntologyVersion[]   @relation("CreatedBy")
  verifiedOntologyVersions OntologyVersion[]   @relation("VerifiedBy")
  enrollments              Enrollment[]
  nodeProgress             LearnerNodeProgress[]
  quizAttempts             QuizAttempt[]
  resourceRatings          ResourceRating[]
  whitelistEntries         DomainWhitelist[]
  adaptationEvents         AdaptationEvent[]
  notifications            Notification[]
  refreshTokens            RefreshToken[]

  @@map("users")
}

model Domain {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now()) @db.Timestamptz

  ontologyVersions OntologyVersion[]
  enrollments      Enrollment[]
  whitelist        DomainWhitelist[]

  @@map("domains")
}

model OntologyVersion {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId      String         @db.Uuid
  versionNumber Int
  status        OntologyStatus @default(draft)
  createdById   String         @db.Uuid
  verifiedById  String?        @db.Uuid
  verifiedAt    DateTime?      @db.Timestamptz
  publishedAt   DateTime?      @db.Timestamptz
  createdAt     DateTime       @default(now()) @db.Timestamptz

  domain      Domain         @relation(fields: [domainId], references: [id])
  createdBy   User           @relation("CreatedBy", fields: [createdById], references: [id])
  verifiedBy  User?          @relation("VerifiedBy", fields: [verifiedById], references: [id])
  nodes       LearningNode[]
  enrollments Enrollment[]

  @@unique([domainId, versionNumber])
  @@map("ontology_versions")
}

model LearningNode {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ontologyVersionId  String      @db.Uuid
  title              String      @db.VarChar(255)
  slug               String      @db.VarChar(255)
  description        String?
  learningOutcomes   Json
  estimatedHours     Decimal?    @db.Decimal(4, 1)
  difficultyLevel    Int?
  isBranchingPoint   Boolean     @default(false)
  isConvergencePoint Boolean     @default(false)
  branchPath         BranchPath?
  positionX          Float?
  positionY          Float?
  createdAt          DateTime    @default(now()) @db.Timestamptz

  ontologyVersion   OntologyVersion       @relation(fields: [ontologyVersionId], references: [id])
  prerequisites     NodePrerequisite[]    @relation("NodePrereqs")
  dependents        NodePrerequisite[]    @relation("PrereqOf")
  progress          LearnerNodeProgress[]
  quizzes           Quiz[]
  quizAttempts      QuizAttempt[]
  resources         Resource[]
  challengeProjects ChallengeProject[]
  adaptationEvents  AdaptationEvent[]

  @@unique([ontologyVersionId, slug])
  @@map("learning_nodes")
}

// Edges of the DAG. Application enforces nodeId != prerequisiteNodeId.
model NodePrerequisite {
  id                 String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId             String @db.Uuid
  prerequisiteNodeId String @db.Uuid

  node             LearningNode @relation("NodePrereqs", fields: [nodeId], references: [id])
  prerequisiteNode LearningNode @relation("PrereqOf", fields: [prerequisiteNodeId], references: [id])

  @@unique([nodeId, prerequisiteNodeId])
  @@index([nodeId])
  @@index([prerequisiteNodeId])
  @@map("node_prerequisites")
}

model Enrollment {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String      @db.Uuid
  domainId           String      @db.Uuid
  ontologyVersionId  String      @db.Uuid
  selectedBranchPath BranchPath?
  enrolledAt         DateTime    @default(now()) @db.Timestamptz

  user            User                  @relation(fields: [userId], references: [id])
  domain          Domain                @relation(fields: [domainId], references: [id])
  ontologyVersion OntologyVersion       @relation(fields: [ontologyVersionId], references: [id])
  nodeProgress    LearnerNodeProgress[]

  @@unique([userId, domainId])
  @@map("enrollments")
}

model LearnerNodeProgress {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @db.Uuid
  nodeId          String       @db.Uuid
  enrollmentId    String       @db.Uuid
  masteryState    MasteryState @default(not_started)
  bestQuizScore   Decimal?     @db.Decimal(5, 2)
  attemptsCount   Int          @default(0)
  // isMarginalPass tracks which decay threshold applies (7-day vs 14-day)
  isMarginalPass  Boolean      @default(false)
  masteredAt      DateTime?    @db.Timestamptz
  lastReviewedAt  DateTime?    @db.Timestamptz
  decayNotifiedAt DateTime?    @db.Timestamptz
  unlocked        Boolean      @default(false)
  createdAt       DateTime     @default(now()) @db.Timestamptz
  updatedAt       DateTime     @updatedAt @db.Timestamptz

  user       User         @relation(fields: [userId], references: [id])
  node       LearningNode @relation(fields: [nodeId], references: [id])
  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id])

  @@unique([userId, nodeId])
  @@index([userId, enrollmentId])
  @@index([masteryState])
  @@index([lastReviewedAt])
  @@map("learner_node_progress")
}

model Quiz {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId      String   @db.Uuid
  isMicroQuiz Boolean  @default(false)
  generatedBy String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @db.Timestamptz

  node      LearningNode   @relation(fields: [nodeId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([nodeId, generatedBy, createdAt])
  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId        String       @db.Uuid
  questionType  QuestionType
  questionText  String
  options       Json?
  correctAnswer String
  explanation   String?
  orderIndex    Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String      @db.Uuid
  quizId       String      @db.Uuid
  nodeId       String      @db.Uuid
  scorePercent Decimal     @db.Decimal(5, 2)
  outcome      QuizOutcome
  answers      Json
  startedAt    DateTime    @db.Timestamptz
  completedAt  DateTime    @db.Timestamptz

  user             User              @relation(fields: [userId], references: [id])
  quiz             Quiz              @relation(fields: [quizId], references: [id])
  node             LearningNode      @relation(fields: [nodeId], references: [id])
  adaptationEvents AdaptationEvent[]

  @@index([userId, nodeId])
  @@map("quiz_attempts")
}

model Resource {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId          String           @db.Uuid
  title           String           @db.VarChar(500)
  url             String
  sourceDomain    String           @db.VarChar(255)
  modality        ResourceModality
  description     String?
  isPrimary       Boolean          @default(false)
  lastValidatedAt DateTime?        @db.Timestamptz
  isValid         Boolean          @default(true)
  avgRating       Decimal          @default(0.00) @db.Decimal(3, 2)
  ratingCount     Int              @default(0)
  fetchedVia      String           @db.VarChar(50)
  createdAt       DateTime         @default(now()) @db.Timestamptz

  node    LearningNode     @relation(fields: [nodeId], references: [id])
  ratings ResourceRating[]

  @@index([nodeId, modality])
  @@map("resources")
}

// Application enforces rating BETWEEN 1 AND 5 via Joi validation.
model ResourceRating {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String   @db.Uuid
  userId     String   @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @db.Timestamptz

  resource Resource @relation(fields: [resourceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([resourceId, userId])
  @@map("resource_ratings")
}

model DomainWhitelist {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId        String           @db.Uuid
  sourceDomain    String           @db.VarChar(255)
  sourceName      String           @db.VarChar(255)
  defaultModality ResourceModality
  addedById       String?          @db.Uuid
  createdAt       DateTime         @default(now()) @db.Timestamptz

  domain  Domain @relation(fields: [domainId], references: [id])
  addedBy User?  @relation(fields: [addedById], references: [id])

  @@unique([domainId, sourceDomain])
  @@index([domainId])
  @@map("domain_whitelist")
}

model AdaptationEvent {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @db.Uuid
  nodeId         String         @db.Uuid
  quizAttemptId  String?        @db.Uuid
  adaptationType AdaptationType
  details        Json?
  createdAt      DateTime       @default(now()) @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id])
  node        LearningNode @relation(fields: [nodeId], references: [id])
  quizAttempt QuizAttempt? @relation(fields: [quizAttemptId], references: [id])

  @@index([userId])
  @@index([nodeId])
  @@index([adaptationType])
  @@index([createdAt])
  @@map("adaptation_events")
}

model ChallengeProject {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId          String   @db.Uuid
  title           String   @db.VarChar(500)
  description     String
  difficultyLevel Int?
  createdAt       DateTime @default(now()) @db.Timestamptz

  node LearningNode @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
  @@map("challenge_projects")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @db.VarChar(255)
  expiresAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
