generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String                @unique @db.VarChar(255)
  passwordHash             String?               @db.VarChar(255)
  fullName                 String                @db.VarChar(255)
  role                     UserRole              @default(learner)
  avatarUrl                String?
  oauthProvider            String?               @db.VarChar(50)
  oauthProviderId          String?               @db.VarChar(255)
  preferredLanguage        String                @default("en") @db.VarChar(10)
  createdAt                DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime              @updatedAt @db.Timestamptz(6)
  adaptationEvents         AdaptationEvent[]
  whitelistEntries         DomainWhitelist[]
  enrollments              Enrollment[]
  nodeProgress             LearnerNodeProgress[]
  notifications            Notification[]
  createdOntologyVersions  OntologyVersion[]     @relation("CreatedBy")
  verifiedOntologyVersions OntologyVersion[]     @relation("VerifiedBy")
  quizAttempts             QuizAttempt[]
  refreshTokens            RefreshToken[]
  resourceRatings          ResourceRating[]
  velocityRecords          LearnerVelocity[]
  xp                       UserXp?
  xpEvents                 XpEvent[]
  badges                   UserBadge[]
  certificates             Certificate[]

  @@map("users")
}

// ── Gamification ──────────────────────────────────────────────────────────────

model UserXp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @db.Uuid                               @map("user_id")
  totalXp   Int      @default(0)                                    @map("total_xp")
  level     Int      @default(1)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)                  @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_xp")
}

model XpEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid                                       @map("user_id")
  source    XpSource
  amount    Int
  refId     String?  @db.Uuid                                       @map("ref_id")
  createdAt DateTime @default(now()) @db.Timestamptz(6)             @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_events")
}

model UserBadge {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String   @db.Uuid                                       @map("user_id")
  badgeKey BadgeKey                                                @map("badge_key")
  earnedAt DateTime @default(now()) @db.Timestamptz(6)             @map("earned_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
  @@map("user_badges")
}

model Domain {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @unique @db.VarChar(100)
  slug             String            @unique @db.VarChar(100)
  description      String?
  iconUrl          String?
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  whitelist        DomainWhitelist[]
  enrollments      Enrollment[]
  ontologyVersions OntologyVersion[]
  certificates     Certificate[]

  @@map("domains")
}

model OntologyVersion {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId      String         @db.Uuid
  versionNumber Int
  status        OntologyStatus @default(draft)
  createdById   String         @db.Uuid
  verifiedById  String?        @db.Uuid
  verifiedAt    DateTime?      @db.Timestamptz(6)
  publishedAt   DateTime?      @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  enrollments   Enrollment[]
  nodes         LearningNode[]
  createdBy     User           @relation("CreatedBy", fields: [createdById], references: [id])
  domain        Domain         @relation(fields: [domainId], references: [id])
  verifiedBy    User?          @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@unique([domainId, versionNumber])
  @@map("ontology_versions")
}

model LearningNode {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ontologyVersionId  String                @db.Uuid
  title              String                @db.VarChar(255)
  slug               String                @db.VarChar(255)
  description        String?
  learningOutcomes   Json
  estimatedHours     Decimal?              @db.Decimal(4, 1)
  difficultyLevel    Int?
  isBranchingPoint   Boolean               @default(false)
  isConvergencePoint Boolean               @default(false)
  branchPath         BranchPath?
  positionX          Float?
  positionY          Float?
  createdAt          DateTime              @default(now()) @db.Timestamptz(6)
  adaptationEvents   AdaptationEvent[]
  challengeProjects  ChallengeProject[]
  progress           LearnerNodeProgress[]
  ontologyVersion    OntologyVersion       @relation(fields: [ontologyVersionId], references: [id])
  prerequisites      NodePrerequisite[]    @relation("NodePrereqs")
  dependents         NodePrerequisite[]    @relation("PrereqOf")
  quizAttempts       QuizAttempt[]
  quizzes              Quiz[]
  resources            Resource[]
  supplementaryNodes   SupplementaryNode[]
  velocityRecords      LearnerVelocity[]

  @@unique([ontologyVersionId, slug])
  @@map("learning_nodes")
}

model NodePrerequisite {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId             String       @db.Uuid
  prerequisiteNodeId String       @db.Uuid
  node               LearningNode @relation("NodePrereqs", fields: [nodeId], references: [id])
  prerequisiteNode   LearningNode @relation("PrereqOf", fields: [prerequisiteNodeId], references: [id])

  @@unique([nodeId, prerequisiteNodeId])
  @@index([nodeId])
  @@index([prerequisiteNodeId])
  @@map("node_prerequisites")
}

model Enrollment {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String                @db.Uuid
  domainId               String                @db.Uuid
  ontologyVersionId      String                @db.Uuid
  selectedBranchPath     BranchPath?
  enrolledAt             DateTime              @default(now()) @db.Timestamptz(6)
  weeklyHours            Int?                  @map("weekly_hours")
  familiarityLevel       String?               @db.VarChar(20) @map("familiarity_level")
  learningGoal           String?               @db.VarChar(30) @map("learning_goal")
  aboutSelf              String?               @map("about_self")
  preferredLearningStyle String?               @db.VarChar(20) @map("preferred_learning_style")
  priorSkills            String?               @map("prior_skills")
  domain                 Domain                @relation(fields: [domainId], references: [id])
  ontologyVersion        OntologyVersion       @relation(fields: [ontologyVersionId], references: [id])
  user                   User                  @relation(fields: [userId], references: [id])
  nodeProgress           LearnerNodeProgress[]
  supplementaryNodes     SupplementaryNode[]
  velocityRecords        LearnerVelocity[]
  certificate            Certificate?

  @@unique([userId, domainId])
  @@map("enrollments")
}

model Certificate {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId      String     @unique @db.VarChar(20)            @map("public_id")
  userId        String     @db.Uuid                           @map("user_id")
  enrollmentId  String     @unique @db.Uuid                   @map("enrollment_id")
  domainId      String     @db.Uuid                           @map("domain_id")
  recipientName String     @db.VarChar(255)                   @map("recipient_name")
  courseName    String     @db.VarChar(255)                   @map("course_name")
  hoursInvested Decimal?   @db.Decimal(6, 1)                  @map("hours_invested")
  averageScore  Decimal?   @db.Decimal(5, 2)                  @map("average_score")
  completedAt   DateTime   @db.Timestamptz(6)                 @map("completed_at")
  issuedAt      DateTime   @default(now()) @db.Timestamptz(6) @map("issued_at")
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  domain        Domain     @relation(fields: [domainId], references: [id])

  @@index([userId])
  @@map("certificates")
}

model SupplementaryNode {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String        @db.Uuid @map("enrollment_id")
  title        String        @db.VarChar(255)
  description  String?
  nodeType     String        @db.VarChar(30) @map("node_type")
  targetNodeId String?       @db.Uuid @map("target_node_id")
  position     String        @db.VarChar(15)
  content      Json?
  createdAt    DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  targetNode   LearningNode? @relation(fields: [targetNodeId], references: [id])

  @@index([enrollmentId])
  @@map("supplementary_nodes")
}

model LearnerVelocity {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String       @db.Uuid @map("user_id")
  enrollmentId   String       @db.Uuid @map("enrollment_id")
  nodeId         String       @db.Uuid @map("node_id")
  estimatedHours Decimal?     @db.Decimal(4, 1) @map("estimated_hours")
  actualHours    Decimal      @db.Decimal(6, 2) @map("actual_hours")
  startedAt      DateTime     @db.Timestamptz(6) @map("started_at")
  completedAt    DateTime     @db.Timestamptz(6) @map("completed_at")
  velocityRatio  Decimal      @db.Decimal(4, 2) @map("velocity_ratio")
  enrollment     Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  node           LearningNode @relation(fields: [nodeId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, nodeId])
  @@index([enrollmentId])
  @@map("learner_velocity")
}

model LearnerNodeProgress {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @db.Uuid
  nodeId          String       @db.Uuid
  enrollmentId    String       @db.Uuid
  masteryState    MasteryState @default(not_started)
  bestQuizScore   Decimal?     @db.Decimal(5, 2)
  attemptsCount   Int          @default(0)
  isMarginalPass  Boolean      @default(false)
  masteredAt      DateTime?    @db.Timestamptz(6)
  lastReviewedAt  DateTime?    @db.Timestamptz(6)
  decayNotifiedAt DateTime?    @db.Timestamptz(6)
  unlocked        Boolean      @default(false)
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @db.Timestamptz(6)
  enrollment      Enrollment   @relation(fields: [enrollmentId], references: [id])
  node            LearningNode @relation(fields: [nodeId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@unique([userId, nodeId])
  @@index([userId, enrollmentId])
  @@index([masteryState])
  @@index([lastReviewedAt])
  @@map("learner_node_progress")
}

model Quiz {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId      String         @db.Uuid
  isMicroQuiz Boolean        @default(false)
  generatedBy String         @db.VarChar(50)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  attempts    QuizAttempt[]
  questions   QuizQuestion[]
  node        LearningNode   @relation(fields: [nodeId], references: [id])

  @@index([nodeId, generatedBy, createdAt])
  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId        String       @db.Uuid
  questionType  QuestionType
  questionText  String
  options       Json?
  correctAnswer String
  explanation   String?
  orderIndex    Int
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String            @db.Uuid
  quizId           String            @db.Uuid
  nodeId           String            @db.Uuid
  scorePercent     Decimal           @db.Decimal(5, 2)
  outcome          QuizOutcome
  answers          Json
  startedAt        DateTime          @db.Timestamptz(6)
  completedAt      DateTime          @db.Timestamptz(6)
  adaptationEvents AdaptationEvent[]
  node             LearningNode      @relation(fields: [nodeId], references: [id])
  quiz             Quiz              @relation(fields: [quizId], references: [id])
  user             User              @relation(fields: [userId], references: [id])

  @@index([userId, nodeId])
  @@map("quiz_attempts")
}

model Resource {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId          String           @db.Uuid
  title           String           @db.VarChar(500)
  url             String
  sourceDomain    String           @db.VarChar(255)
  modality        ResourceModality
  description     String?
  isPrimary       Boolean          @default(false)
  lastValidatedAt DateTime?        @db.Timestamptz(6)
  isValid         Boolean          @default(true)
  avgRating       Decimal          @default(0.00) @db.Decimal(3, 2)
  ratingCount     Int              @default(0)
  fetchedVia      String           @db.VarChar(50)
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  ratings         ResourceRating[]
  node            LearningNode     @relation(fields: [nodeId], references: [id])

  @@index([nodeId, modality])
  @@map("resources")
}

model ResourceRating {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId String   @db.Uuid
  userId     String   @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  resource   Resource @relation(fields: [resourceId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([resourceId, userId])
  @@map("resource_ratings")
}

model DomainWhitelist {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId        String           @db.Uuid
  sourceDomain    String           @db.VarChar(255)
  sourceName      String           @db.VarChar(255)
  defaultModality ResourceModality
  addedById       String?          @db.Uuid
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  addedBy         User?            @relation(fields: [addedById], references: [id])
  domain          Domain           @relation(fields: [domainId], references: [id])

  @@unique([domainId, sourceDomain])
  @@index([domainId])
  @@map("domain_whitelist")
}

model AdaptationEvent {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @db.Uuid
  nodeId         String         @db.Uuid
  quizAttemptId  String?        @db.Uuid
  adaptationType AdaptationType
  details        Json?
  createdAt      DateTime       @default(now()) @db.Timestamptz(6)
  node           LearningNode   @relation(fields: [nodeId], references: [id])
  quizAttempt    QuizAttempt?   @relation(fields: [quizAttemptId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([nodeId])
  @@index([adaptationType])
  @@index([createdAt])
  @@map("adaptation_events")
}

model ChallengeProject {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId          String       @db.Uuid
  title           String       @db.VarChar(500)
  description     String
  difficultyLevel Int?
  createdAt       DateTime     @default(now()) @db.Timestamptz(6)
  node            LearningNode @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
  @@map("challenge_projects")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @db.VarChar(255)
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum UserRole {
  learner
  domain_expert
  admin
}

enum MasteryState {
  not_started
  in_progress
  mastered
  review_needed
  relearn
}

enum QuizOutcome {
  strong_pass
  marginal_pass
  fail_low
  fail_fundamental
  fail_severe
}

enum QuestionType {
  multiple_choice
  short_answer
  code_completion
  true_false
  matching
}

enum ResourceModality {
  documentation
  tutorial
  video
  interactive
  reference
}

enum OntologyStatus {
  draft
  in_review
  verified
  published
  archived
}

enum AdaptationType {
  resource_swap
  prerequisite_review
  instructor_escalation
  decay_micro_quiz
}

enum BranchPath {
  frontend
  backend
  data_science
}

enum XpSource {
  node_mastered_strong
  node_mastered_marginal
  quiz_attempt
  spaced_review
  streak_milestone
  enrollment_complete
}

enum BadgeKey {
  first_mastery
  streak_5
  streak_14
  quiz_ace
  speed_learner
  completionist
  consistent
  comeback
}
