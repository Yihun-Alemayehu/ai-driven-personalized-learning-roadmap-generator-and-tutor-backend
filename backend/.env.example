# Common
NODE_ENV=development

# Ports
API_GATEWAY_PORT=3000
LEARNING_SERVICE_PORT=3001
AI_SERVICE_PORT=3002

# Public origin (recommended in production when behind TLS proxies/LBs)
# Example: https://api.yegna-future.site
PUBLIC_ORIGIN=

# Database (shared by api-gateway and learning-service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/learner_roadmap

# Redis (shared by all services)
REDIS_URL=redis://localhost:6379

# JWT (api-gateway)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth (api-gateway)
FRONTEND_CALLBACK_URL=http://localhost:5173/auth/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/google/callback
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/github/callback

# Rate limiting (api-gateway)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Service URLs (Docker internal network — used by api-gateway to proxy)
LEARNING_SERVICE_URL=http://learning-service:3001
AI_SERVICE_URL=http://ai-service:3002

# Gemini AI (ai-service) — obtain from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Google Programmable Search Engine (ai-service)
GOOGLE_PSE_API_KEY=your-pse-api-key
GOOGLE_PSE_ENGINE_ID=your-pse-engine-id

# Logging
LOG_LEVEL=info
